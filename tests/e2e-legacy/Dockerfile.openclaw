# E2E test environment with OpenClaw
FROM node:22-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv curl git jq \
    && rm -rf /var/lib/apt/lists/*

# Install OpenClaw CLI
RUN npm install -g openclaw

# Install ipman from PyPI (or local wheel via build arg)
ARG IPMAN_VERSION=latest
RUN pip3 install --break-system-packages \
    $([ "$IPMAN_VERSION" = "latest" ] && echo "ipman-cli" || echo "ipman-cli==$IPMAN_VERSION")

# Verify installations
RUN openclaw --version || echo "OpenClaw installed"
RUN ipman --version

WORKDIR /workspace
COPY scenarios/ /workspace/scenarios/
COPY run-tests.sh /workspace/

ENTRYPOINT ["bash", "/workspace/run-tests.sh"]
CMD ["openclaw"]
